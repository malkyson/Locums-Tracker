                <div style={styles.col}>
                  <label style={styles.label}>Misc pts</label>
                  <input type="number" style={styles.input} value={miscPts} onChange={e => setMiscPts(e.target.value)} placeholder="0" />
                </div>
                <div style={{ flex: 2 }}>
