              </div>
              {anesStart && anesEnd && (
                <div style={{ marginBottom: 12, marginTop: -6, fontSize: 12, color: "#4a90d9", fontWeight: 600 }}>
                  → {calcMaintenanceUnits(anesStart, anesEnd)} maintenance units
