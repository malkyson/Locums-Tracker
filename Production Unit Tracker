    histLabel: { fontSize: 14, color: "#e8eaf0", fontWeight: 500 },
    histPts: { fontSize: 15, fontWeight: 700, color: "#4a90d9", marginRight: 10 },
    deleteBtn: { background: "transparent", border: "none", color: "#3a3d50", fontSize: 18, cursor: "pointer", padding: "0 4px" },
    toast: { position: "fixed", bottom: 90, left: "50%", transform: "translateX(-50%)", background: "#4a90d9", color: "#fff", padding: "10px 24px", borderRadius: 20, fontWeight: 700, fontSize: 14, zIndex: 100, pointerEvents: "none", opacity: toast ? 1 : 0, transition: "opacity 0.3s" },
    monthSelector: { display: "flex", gap: 8, alignItems: "center", marginBottom: 16 },
    monthBtn: { background: "#1a1d2e", border: "1px solid #2a2d3e", color: "#6b7280", borderRadius: 8, padding: "6px 12px", cursor: "pointer", fontSize: 14 },
    monthLabel: { flex: 1, textAlign: "center", fontWeight: 700, fontSize: 15, color: "#e8eaf0" },
    grandTotal: { background: "#1a3a5c", borderRadius: 12, padding: "14px 16px", marginBottom: 16, display: "flex", justifyContent: "space-between", alignItems: "center" },
    grandTotalLabel: { fontSize: 13, fontWeight: 700, letterSpacing: "0.06em", color: "#4a90d9", textTransform: "uppercase" },
    grandTotalNum: { fontSize: 26, fontWeight: 800, color: "#4a90d9" },
  };

  const filtered = filteredEntries();
  const cats = groupByCategory(filtered);
  const monthTotal = Object.values(cats).reduce((s, c) => s + c.pts, 0);

  function prevMonth() {
    if (month === 0) { setMonth(11); setYear(y => y - 1); } else setMonth(m => m - 1);
  }
  function nextMonth() {
    if (month === 11) { setMonth(0); setYear(y => y + 1); } else setMonth(m => m + 1);
  }

  const Stepper = ({ val, setVal, min = 0 }) => (
    <div style={styles.stepper}>
      <button style={styles.stepBtn} onClick={() => setVal(v => Math.max(min, (parseInt(v) || 0) - 1))}>−</button>
      <span style={styles.stepVal}>{val}</span>
      <button style={styles.stepBtn} onClick={() => setVal(v => (parseInt(v) || 0) + 1)}>+</button>
    </div>
  );

