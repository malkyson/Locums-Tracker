        <div style={styles.headerTitle}>MAO Tracker</div>
        <div style={styles.headerSub}>Production Units</div>
        <div style={styles.total}>
          This month: <span style={styles.totalNum}>{totalPts(entries.filter(e => { const d = new Date(e.date + "T12:00:00"); return d.getMonth() === defaultMonth && d.getFullYear() === defaultYear; })).toFixed(2)} pts</span>
        </div>
      </div>

      <div style={styles.nav}>
        <button style={styles.navBtn(view === "log")} onClick={() => setView("log")}>Log Entry</button>
