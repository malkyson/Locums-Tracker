    }),
    section: { padding: "16px 20px" },
    label: { fontSize: 11, fontWeight: 700, letterSpacing: "0.08em", color: "#6b7280", textTransform: "uppercase", marginBottom: 6, display: "block" },
    input: { width: "100%", background: "#1a1d2e", border: "1px solid #2a2d3e", borderRadius: 10, padding: "11px 14px", color: "#e8eaf0", fontSize: 15, boxSizing: "border-box", outline: "none" },
    select: { width: "100%", background: "#1a1d2e", border: "1px solid #2a2d3e", borderRadius: 10, padding: "11px 14px", color: "#e8eaf0", fontSize: 15, boxSizing: "border-box", outline: "none", appearance: "none" },
    row: { display: "flex", gap: 10, marginBottom: 12 },
    col: { flex: 1 },
    stepper: { display: "flex", alignItems: "center", gap: 0, background: "#1a1d2e", borderRadius: 10, border: "1px solid #2a2d3e", overflow: "hidden" },
    stepBtn: { width: 44, height: 44, border: "none", background: "transparent", color: "#4a90d9", fontSize: 20, cursor: "pointer", flexShrink: 0 },
    stepVal: { flex: 1, textAlign: "center", fontSize: 17, fontWeight: 700, color: "#e8eaf0" },
    toggle: (on) => ({ padding: "10px 14px", borderRadius: 10, border: `1px solid ${on ? "#4a90d9" : "#2a2d3e"}`, background: on ? "#1a3a5c" : "#1a1d2e", color: on ? "#4a90d9" : "#6b7280", fontWeight: 600, fontSize: 13, cursor: "pointer", flex: 1, textAlign: "center" }),
