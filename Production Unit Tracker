                    {CONSULTS.map(p => <option key={p.id} value={p.id}>{p.label} ({p.pts} pts)</option>)}
                  </optgroup>
                </select>
              </div>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Quantity</label>
                <Stepper val={procQty} setVal={setProcQty} min={1} />
              </div>
              <button style={styles.submitBtn} onClick={submitProcedure}>Log Procedure</button>
            </>
          )}

          {entryType === "call" && (
            <>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Date</label>
                <input type="date" style={styles.input} value={callDate} onChange={e => setCallDate(e.target.value)} />
              </div>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Call Position</label>
                <select style={styles.select} value={shiftId} onChange={e => setShiftId(e.target.value)}>
                  {CALL_SHIFTS.map(s => <option key={s.id} value={s.id}>{s.label} ({s.pts} pts)</option>)}
                </select>
              </div>
              <button style={styles.submitBtn} onClick={submitCall}>Log Call Shift</button>
            </>
          )}

          {entryType === "drive" && (
            <>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Date</label>
                <input type="date" style={styles.input} value={driveDate} onChange={e => setDriveDate(e.target.value)} />
              </div>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Site</label>
                <select style={styles.select} value={driveSiteId} onChange={e => setDriveSiteId(e.target.value)}>
                  {DRIVE_STIPENDS.map(s => <option key={s.id} value={s.id}>{s.label} ({s.pts} pts)</option>)}
                </select>
              </div>
              <button style={styles.submitBtn} onClick={submitDrive}>Log Drive Stipend</button>
            </>
          )}

          {entryType === "pacu_supervision" && (
            <>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Date</label>
                <input type="date" style={styles.input} value={pacuSupDate} onChange={e => setPacuSupDate(e.target.value)} />
              </div>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Site</label>
                <select style={styles.select} value={pacuSupSiteId} onChange={e => setPacuSupSiteId(e.target.value)}>
                  {PACU_SITES.map(s => <option key={s.id} value={s.id}>{s.label} ({s.pts} pts)</option>)}
                </select>
              </div>
              <button style={styles.submitBtn} onClick={submitPacuSup}>Log PACU Supervision</button>
            </>
          )}

          {entryType === "standby" && (
            <>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Date</label>
                <input type="date" style={styles.input} value={standbyDate} onChange={e => setStandbyDate(e.target.value)} />
              </div>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Type</label>
                <select style={styles.select} value={standbyId} onChange={e => setStandbyId(e.target.value)}>
                  {STANDBY.map(s => <option key={s.id} value={s.id}>{s.label} ({s.pts} pts)</option>)}
                </select>
              </div>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Number of 15-min intervals</label>
                <Stepper val={standbyQty} setVal={setStandbyQty} min={1} />
              </div>
              <button style={styles.submitBtn} onClick={submitStandby}>Log Standby</button>
            </>
          )}

          {entryType === "assist" && (
            <>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Date</label>
                <input type="date" style={styles.input} value={assistDate} onChange={e => setAssistDate(e.target.value)} />
              </div>
              <div style={{ marginBottom: 12 }}>
                <label style={styles.label}>Number of assists</label>
                <Stepper val={assistQty} setVal={setAssistQty} min={1} />
              </div>
              <button style={styles.submitBtn} onClick={submitAssist}>Log OR Assist</button>
            </>
          )}
        </div>
      )}

      {/* SUMMARY VIEW */}
      {view === "summary" && (
        <div style={styles.section}>
          <div style={styles.monthSelector}>
            <button style={styles.monthBtn} onClick={prevMonth}>‹</button>
            <div style={styles.monthLabel}>{MONTHS[month]} {year}</div>
            <button style={styles.monthBtn} onClick={nextMonth}>›</button>
          </div>
          <div style={styles.grandTotal}>
            <div style={styles.grandTotalLabel}>Total Points</div>
            <div style={styles.grandTotalNum}>{monthTotal.toFixed(2)}</div>
          </div>
          {Object.entries(cats).map(([cat, data]) => (
            (data.pts > 0 || data.count > 0) ? (
              <div key={cat} style={styles.summaryRow}>
                <div>
                  <div style={styles.summaryLabel}>{cat}</div>
                  <div style={styles.summaryCount}>{data.count} unit{data.count !== 1 ? "s" : ""}</div>
                </div>
                <div style={{ textAlign: "right" }}>
                  <div style={styles.summaryPts}>{data.pts.toFixed(2)} pts</div>
                </div>
              </div>
            ) : null
          ))}
          {filtered.length === 0 && <div style={{ color: "#6b7280", textAlign: "center", marginTop: 40 }}>No entries for this month.</div>}
        </div>
      )}

      {/* HISTORY VIEW */}
      {view === "history" && (
        <div style={styles.section}>
          <div style={styles.monthSelector}>
            <button style={styles.monthBtn} onClick={prevMonth}>‹</button>
            <div style={styles.monthLabel}>{MONTHS[month]} {year}</div>
            <button style={styles.monthBtn} onClick={nextMonth}>›</button>
          </div>
          {filtered.length === 0 && <div style={{ color: "#6b7280", textAlign: "center", marginTop: 40 }}>No entries for this month.</div>}
          {filtered.sort((a, b) => b.date.localeCompare(a.date)).map(e => (
            <div key={e.id} style={styles.historyItem}>
              <div>
                <div style={styles.histDate}>{formatDate(e.date)}</div>
                <div style={styles.histLabel}>{entryLabel(e)}</div>
                {e.miscNote ? <div style={{ fontSize: 11, color: "#6b7280", marginTop: 2 }}>{e.miscNote}</div> : null}
              </div>
              <div style={{ display: "flex", alignItems: "center" }}>
                <div style={styles.histPts}>{entryPts(e).toFixed(2)}</div>
                <button style={styles.deleteBtn} onClick={() => deleteEntry(e.id)}>×</button>
              </div>
            </div>
          ))}
        </div>
      )}

      <div style={styles.toast}>{toast}</div>
    </div>
  );
}
