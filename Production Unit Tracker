const MONTHS = ["January","February","March","April","May","June","July","August","September","October","November","December"];

const today = new Date();
const defaultMonth = today.getMonth();
const defaultYear = today.getFullYear();

function formatDate(d) {
  return d ? new Date(d + "T12:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric" }) : "";
}

function groupByCategory(entries) {
  const cats = {
    "Case Starts": { pts: 0, count: 0 },
    "Case Maintenance": { pts: 0, count: 0 },
    "Procedures": { pts: 0, count: 0 },
    "Consults": { pts: 0, count: 0 },
    "A-Lines": { pts: 0, count: 0 },
    "Central Lines": { pts: 0, count: 0 },
    "PACU Mgmt": { pts: 0, count: 0 },
    "Rounding": { pts: 0, count: 0 },
    "Standby": { pts: 0, count: 0 },
    "OR Assist": { pts: 0, count: 0 },
    "Call Shifts": { pts: 0, count: 0 },
    "Drive Stipends": { pts: 0, count: 0 },
    "PACU Supervision": { pts: 0, count: 0 },
    "Misc": { pts: 0, count: 0 },
  };
  for (const e of entries) {
    const add = (cat, pts, count = 1) => {
      cats[cat].pts += pts;
      cats[cat].count += count;
    };
    if (e.type === "case") {
      add("Case Starts", e.caseStarts * 1, e.caseStarts);
      add("Case Maintenance", e.maintenanceUnits * 1, e.maintenanceUnits);
      if (e.aline) add("A-Lines", 0, 1);
      if (e.centralLine) add("Central Lines", 0, 1);
      if (e.pacu15min > 0) add("PACU Mgmt", e.pacu15min * 1, e.pacu15min);
      if (e.rounding > 0) add("Rounding", 0, e.rounding);
      if (e.miscPts) add("Misc", parseFloat(e.miscPts) || 0, 1);
    } else if (e.type === "procedure") {
      const proc = [...PROCEDURES, ...CONSULTS].find(p => p.id === e.procedureId);
      if (proc) add(CONSULTS.find(c => c.id === e.procedureId) ? "Consults" : "Procedures", proc.pts * (e.qty || 1), e.qty || 1);
    } else if (e.type === "standby") {
      const s = STANDBY.find(x => x.id === e.standbyId);
      if (s) add("Standby", s.pts * (e.qty || 1), e.qty || 1);
    } else if (e.type === "assist") {
      add("OR Assist", 0.5 * (e.qty || 1), e.qty || 1);
    } else if (e.type === "call") {
      const shift = CALL_SHIFTS.find(s => s.id === e.shiftId);
      if (shift) add("Call Shifts", shift.pts, 1);
    } else if (e.type === "drive") {
      const site = DRIVE_STIPENDS.find(s => s.id === e.siteId);
      if (site) add("Drive Stipends", site.pts, 1);
    } else if (e.type === "pacu_supervision") {
      const site = PACU_SITES.find(s => s.id === e.siteId);
      if (site) add("PACU Supervision", site.pts, 1);
    }
  }
  return cats;
}

function calcMaintenanceUnits(start, end) {
  if (!start || !end) return 0;
  const [sh, sm] = start.split(":").map(Number);
  let [eh, em] = end.split(":").map(Number);
  let totalMins = (eh * 60 + em) - (sh * 60 + sm);
  if (totalMins < 0) totalMins += 24 * 60; // overnight case
  return Math.floor(totalMins / 15);
}


function totalPts(entries) {
  const cats = groupByCategory(entries);
  return Object.values(cats).reduce((sum, c) => sum + c.pts, 0);
}

export default function App() {
  const [view, setView] = useState("log"); // log | summary | history
  const [entries, setEntries] = useState([]);
  const [month, setMonth] = useState(defaultMonth);
  const [year, setYear] = useState(defaultYear);
  const [entryType, setEntryType] = useState("case");
  const [toast, setToast] = useState("");

  // Case form
  const [caseDate, setCaseDate] = useState(today.toISOString().slice(0, 10));
  const [caseStarts, setCaseStarts] = useState(1);
  const [anesStart, setAnesStart] = useState("");
  const [anesEnd, setAnesEnd] = useState("");
  const [aline, setAline] = useState(false);
  const [centralLine, setCentralLine] = useState(false);
  const [pacu15min, setPacu15min] = useState(0);
  const [rounding, setRounding] = useState(0);
  const [miscPts, setMiscPts] = useState("");
  const [miscNote, setMiscNote] = useState("");

  // Procedure form
  const [procDate, setProcDate] = useState(today.toISOString().slice(0, 10));
  const [procedureId, setProcedureId] = useState(PROCEDURES[0].id);
  const [procQty, setProcQty] = useState(1);

  // Standby
  const [standbyDate, setStandbyDate] = useState(today.toISOString().slice(0, 10));
  const [standbyId, setStandbyId] = useState(STANDBY[0].id);
  const [standbyQty, setStandbyQty] = useState(1);

  // OR Assist
  const [assistDate, setAssistDate] = useState(today.toISOString().slice(0, 10));
  const [assistQty, setAssistQty] = useState(1);

  // Call shift
  const [callDate, setCallDate] = useState(today.toISOString().slice(0, 10));
  const [shiftId, setShiftId] = useState(CALL_SHIFTS[0].id);

  // Drive stipend
  const [driveDate, setDriveDate] = useState(today.toISOString().slice(0, 10));
  const [driveSiteId, setDriveSiteId] = useState(DRIVE_STIPENDS[0].id);

  // PACU supervision
  const [pacuSupDate, setPacuSupDate] = useState(today.toISOString().slice(0, 10));
  const [pacuSupSiteId, setPacuSupSiteId] = useState(PACU_SITES[0].id);

  useEffect(() => {
    async function load() {
      try {
        const r = await window.storage.get("mao_entries");
        if (r) setEntries(JSON.parse(r.value));
      } catch {}
    }
    load();
  }, []);

  async function saveEntries(updated) {
    setEntries(updated);
    try { await window.storage.set("mao_entries", JSON.stringify(updated)); } catch {}
  }

  function showToast(msg) {
    setToast(msg);
    setTimeout(() => setToast(""), 2000);
  }

  function filteredEntries() {
    return entries.filter(e => {
      const d = new Date(e.date + "T12:00:00");
      return d.getMonth() === month && d.getFullYear() === year;
    });
  }

  function addEntry(entry) {
    const updated = [entry, ...entries];
    saveEntries(updated);
    showToast("Logged ✓");
  }

  function deleteEntry(id) {
    saveEntries(entries.filter(e => e.id !== id));
  }

  function submitCase() {
    const maintenanceUnits = calcMaintenanceUnits(anesStart, anesEnd);
    addEntry({
      id: Date.now().toString(),
      type: "case",
      date: caseDate,
      caseStarts: parseInt(caseStarts) || 0,
      maintenanceUnits,
      anesStart, anesEnd,
      aline, centralLine,
      pacu15min: parseInt(pacu15min) || 0,
      rounding: parseInt(rounding) || 0,
      miscPts: parseFloat(miscPts) || 0,
      miscNote,
    });
    setCaseStarts(1); setAnesStart(""); setAnesEnd(""); setAline(false); setCentralLine(false);
    setPacu15min(0); setRounding(0); setMiscPts(""); setMiscNote("");
  }

  function submitProcedure() {
    addEntry({ id: Date.now().toString(), type: "procedure", date: procDate, procedureId, qty: parseInt(procQty) || 1 });
    setProcQty(1);
  }

  function submitStandby() {
    addEntry({ id: Date.now().toString(), type: "standby", date: standbyDate, standbyId, qty: parseInt(standbyQty) || 1 });
    setStandbyQty(1);
  }

  function submitAssist() {
    addEntry({ id: Date.now().toString(), type: "assist", date: assistDate, qty: parseInt(assistQty) || 1 });
    setAssistQty(1);
  }

  function submitCall() {
    addEntry({ id: Date.now().toString(), type: "call", date: callDate, shiftId });
  }

  function submitDrive() {
    addEntry({ id: Date.now().toString(), type: "drive", date: driveDate, siteId: driveSiteId });
  }

  function submitPacuSup() {
    addEntry({ id: Date.now().toString(), type: "pacu_supervision", date: pacuSupDate, siteId: pacuSupSiteId });
  }

  function entryLabel(e) {
    if (e.type === "case") return `Case: ${e.caseStarts} start${e.caseStarts !== 1 ? "s" : ""}, ${e.maintenanceUnits} maint. units`;
    if (e.type === "procedure") {
      const p = [...PROCEDURES, ...CONSULTS].find(x => x.id === e.procedureId);
      return `${p?.label || e.procedureId} ×${e.qty}`;
    }
    if (e.type === "standby") {
      const s = STANDBY.find(x => x.id === e.standbyId);
      return `${s?.label || e.standbyId} ×${e.qty}`;
    }
    if (e.type === "assist") return `OR Assist ×${e.qty}`;
    if (e.type === "call") {
      const s = CALL_SHIFTS.find(x => x.id === e.shiftId);
      return `Call: ${s?.label || e.shiftId}`;
    }
    if (e.type === "drive") {
      const s = DRIVE_STIPENDS.find(x => x.id === e.siteId);
      return `Drive stipend: ${s?.label}`;
